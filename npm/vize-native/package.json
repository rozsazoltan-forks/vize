{
  "name": "@vizejs/native",
  "version": "0.58.0",
  "description": "High-performance Vue.js compiler - Native bindings",
  "keywords": [
    "compiler",
    "napi",
    "native",
    "rust",
    "vize",
    "vue"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build-local.mjs --release",
    "build:debug": "node ./scripts/build-local.mjs",
    "prepublishOnly": "napi pre-publish -t npm --no-gh-release --skip-optional-publish"
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:integrations"
  },
  "napi": {
    "binaryName": "vize-vitrine",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  }
}
