{
  "name": "@vizejs/native",
  "version": "0.103.0",
  "description": "High-performance Vue.js compiler - Native bindings",
  "keywords": [
    "compiler",
    "napi",
    "native",
    "rust",
    "vize",
    "vue"
  ],
  "homepage": "https://github.com/ubugeeei/vize",
  "bugs": {
    "url": "https://github.com/ubugeeei/vize/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "native-binding.js",
    "native-targets.js",
    "types"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build-local.mjs --release",
    "build:ci": "napi build --platform --profile ci --manifest-path ../../crates/vize_vitrine/Cargo.toml -p vize_vitrine --features napi --output-dir .",
    "build:debug": "node ./scripts/build-local.mjs",
    "prepublishOnly": "napi pre-publish -t npm --no-gh-release --skip-optional-publish"
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:integrations"
  },
  "optionalDependencies": {
    "@vizejs/native-darwin-arm64": "catalog:native-binaries",
    "@vizejs/native-darwin-x64": "catalog:native-binaries",
    "@vizejs/native-linux-arm64-gnu": "catalog:native-binaries",
    "@vizejs/native-linux-arm64-musl": "catalog:native-binaries",
    "@vizejs/native-linux-x64-gnu": "catalog:native-binaries",
    "@vizejs/native-linux-x64-musl": "catalog:native-binaries",
    "@vizejs/native-win32-arm64-msvc": "catalog:native-binaries",
    "@vizejs/native-win32-x64-msvc": "catalog:native-binaries"
  },
  "napi": {
    "binaryName": "vize-vitrine",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
