{
  "name": "@vizejs/rspack-plugin",
  "version": "0.71.0",
  "description": "High-performance Rspack plugin for Vue SFC compilation powered by Vize",
  "keywords": [
    "compiler",
    "fast",
    "loader",
    "native",
    "plugin",
    "rspack",
    "sfc",
    "vue"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize",
    "directory": "npm/rspack-vize-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./loader": {
      "types": "./dist/loader/index.d.mts",
      "import": "./dist/loader/index.mjs",
      "default": "./dist/loader/index.mjs"
    },
    "./style-loader": {
      "types": "./dist/loader/style-loader.d.mts",
      "import": "./dist/loader/style-loader.mjs",
      "default": "./dist/loader/style-loader.mjs"
    },
    "./scope-loader": {
      "types": "./dist/loader/scope-loader.d.mts",
      "import": "./dist/loader/scope-loader.mjs",
      "default": "./dist/loader/scope-loader.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts",
    "test": "pnpm build && node --test src/*.test.ts src/**/*.test.ts",
    "test:update": "pnpm build && node --test --test-update-snapshots src/*.test.ts src/**/*.test.ts"
  },
  "dependencies": {
    "@vizejs/native": "workspace:*"
  },
  "devDependencies": {
    "@rspack/core": "catalog:bundlers",
    "@tsdown/css": "catalog:content",
    "@types/node": "catalog:typescript",
    "tsdown": "catalog:vite-stack",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite-stack",
    "vite-plus": "catalog:vite-stack"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  }
}
