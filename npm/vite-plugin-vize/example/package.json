{
  "name": "vite-plugin-vize-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --config vite.app.config.ts",
    "build": "vp build --config vite.app.config.ts",
    "preview": "vp preview --config vite.app.config.ts",
    "check": "vp check src vite.config.ts vite.app.config.ts vize.config.ts",
    "check:fix": "vp check --fix src vite.config.ts vite.app.config.ts vize.config.ts",
    "fmt": "vp fmt --write src vite.config.ts vite.app.config.ts vize.config.ts"
  },
  "dependencies": {
    "vue": "catalog:vue-stable"
  },
  "devDependencies": {
    "@vizejs/vite-plugin": "workspace:*",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite-stack",
    "vite-plugin-inspect": "catalog:vite-stack",
    "vite-plus": "catalog:vite-stack",
    "vize": "workspace:*"
  }
}
