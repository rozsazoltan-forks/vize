{
  "name": "@vizejs/musea-mcp-server",
  "version": "0.63.0",
  "description": "MCP server for building Vue.js design systems - component analysis, documentation, variant generation, and design tokens",
  "keywords": [
    "ai",
    "component-analysis",
    "design-system",
    "mcp",
    "model-context-protocol",
    "musea",
    "vue"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize.git",
    "directory": "npm/musea-mcp-server"
  },
  "bin": {
    "musea-mcp": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "start": "node dist/cli.mjs",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:integrations",
    "@vizejs/native": "workspace:*"
  },
  "devDependencies": {
    "@tsdown/css": "catalog:content",
    "@types/node": "catalog:typescript",
    "tsdown": "catalog:vite-stack",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite-stack",
    "vite-plus": "catalog:vite-stack"
  }
}
