{
  "name": "@vizejs/vite-plugin-musea",
  "version": "0.53.0",
  "description": "Vite plugin for Musea - Component gallery for Vue components",
  "keywords": [
    "component-gallery",
    "musea",
    "storybook",
    "vite",
    "vite-plugin",
    "vue"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vize.git",
    "directory": "npm/vite-plugin-musea"
  },
  "bin": {
    "musea-vrt": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "dist/gallery",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./vrt": {
      "import": "./dist/vrt.mjs",
      "types": "./dist/vrt.d.mts"
    },
    "./cli": {
      "import": "./dist/cli/index.mjs",
      "types": "./dist/cli/index.d.mts"
    },
    "./a11y": {
      "import": "./dist/a11y/index.mjs",
      "types": "./dist/a11y/index.d.mts"
    },
    "./autogen": {
      "import": "./dist/autogen/index.mjs",
      "types": "./dist/autogen/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && pnpm --dir ../.. install --frozen-lockfile --prefer-offline --filter @vizejs/vite-plugin-musea... && vp build --config gallery-vite.config.ts",
    "build:gallery": "vp build --config gallery-vite.config.ts",
    "dev": "vp pack --watch",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts"
  },
  "dependencies": {
    "@vizejs/native": "workspace:*",
    "pngjs": "catalog:content"
  },
  "devDependencies": {
    "@mdi/js": "catalog:content",
    "@tsdown/css": "catalog:content",
    "@types/node": "catalog:typescript",
    "@types/pngjs": "catalog:content",
    "@vitejs/plugin-vue": "catalog:vite-stack",
    "@vizejs/vite-plugin": "workspace:*",
    "highlight.js": "catalog:content",
    "marked": "catalog:content",
    "marked-highlight": "catalog:content",
    "monaco-editor": "catalog:content",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite-stack",
    "vite-plus": "catalog:vite-stack",
    "vue": "catalog:vue-stable",
    "vue-router": "catalog:vue-stable"
  },
  "peerDependencies": {
    "@vizejs/vite-plugin": "workspace:*",
    "axe-core": "^4.7.0",
    "playwright": "^1.40.0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "axe-core": {
      "optional": true
    }
  }
}
