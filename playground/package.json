{
  "name": "vize-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --config vite.app.config.ts",
    "build": "vp build --config vite.app.config.ts",
    "preview": "vp preview --config vite.app.config.ts",
    "test": "pnpm test:node && pnpm test:browser",
    "test:node": "vp test run --config vite.node.config.ts",
    "test:browser": "CI=1 vp test run --config vite.test.config.ts",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots",
    "check": "ROOT=\"$(cd .. && pwd -P)\" && vp check src 'e2e/*.ts' 'e2e/vrt/*.ts' vite.config.ts vite.app.config.ts vite.test.config.ts vite.node.config.ts playwright.config.ts && cargo run --quiet --manifest-path \"$ROOT/Cargo.toml\" -p vize -- lint --max-warnings 0",
    "check:fix": "vp check --fix src 'e2e/*.ts' 'e2e/vrt/*.ts' vite.config.ts vite.app.config.ts vite.test.config.ts vite.node.config.ts playwright.config.ts",
    "fmt": "vp fmt --write src",
    "build:wasm": "vp run --workspace-root build:wasm-web"
  },
  "dependencies": {
    "@mdi/js": "catalog:content",
    "monaco-editor": "catalog:content",
    "prettier": "catalog:repo-tooling",
    "shiki": "catalog:content",
    "typescript": "catalog:typescript",
    "vue": "catalog:vue-beta"
  },
  "devDependencies": {
    "@playwright/test": "catalog:testing",
    "@vizejs/vite-plugin": "workspace:*",
    "@vue/test-utils": "catalog:vue-stable",
    "playwright": "catalog:testing",
    "vite": "catalog:vite-stack",
    "vite-plus": "catalog:vite-stack"
  }
}
